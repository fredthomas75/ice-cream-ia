# =============================================================================
# Glacé IA — variables d'environnement
# =============================================================================
# Copier ce fichier en .env.local pour le dev :
#   cp .env.example .env.local
#
# Sur Vercel, ajouter ces variables dans :
#   Project Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Stripe — paiement
# -----------------------------------------------------------------------------
# Récupérer les clés sur https://dashboard.stripe.com/test/apikeys
# Mode TEST : préfixes sk_test_… et pk_test_…
# Mode LIVE : préfixes sk_live_… et pk_live_…
#
# Si STRIPE_SECRET_KEY n'est PAS définie, le site tombe gracieusement sur un
# tunnel simulé (utile pour le développement local sans configurer Stripe).
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# URL publique du site (utilisée pour les redirections Stripe success/cancel)
# -----------------------------------------------------------------------------
# Local :     http://localhost:3000
# Preview :   automatique via VERCEL_URL
# Prod :      https://votre-domaine.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
